# Streamlit Community Cloud secrets template.
#
# 로컬: .env 파일을 그대로 쓰시면 됩니다. 이 파일은 배포용 템플릿입니다.
# 배포: Streamlit Cloud 앱 대시보드 > Settings > Secrets 에
#       아래 내용을 복사한 뒤 값만 본인 것으로 치환해 붙여넣으세요.

G2B_SERVICE_KEY = "여기에_data.go.kr에서_발급받은_서비스키"

# KEPCO는 bigdata.kepco.co.kr 전용 키 (data.go.kr 공용 키와 별개)
KEPCO_API_KEY = ""

# 이메일 알림 쓰려면 (Gmail은 앱 비밀번호 필요)
SMTP_USER = ""
SMTP_PASS = ""

# Slack 알림 쓰려면
SLACK_WEBHOOK_URL = ""
